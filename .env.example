# Shovs LLM OS Environment Variables

# LLM
# Provider options:
#   auto          = prefer LM Studio -> llama.cpp -> local OpenAI -> OpenAI cloud -> other configured providers -> Ollama
#   ollama        = Ollama local server
#   lmstudio      = LM Studio local server (OpenAI-compatible)
#   llamacpp      = llama.cpp local server (OpenAI-compatible)
#   local_openai  = another local/self-hosted OpenAI-compatible server
#   openai        = OpenAI cloud
#   groq          = Groq cloud
#   gemini        = Google Gemini
#   anthropic     = Anthropic Claude
LLM_PROVIDER=auto

# Active chat model for the selected provider.
# Examples:
#   DEFAULT_MODEL=llama3.2
#   DEFAULT_MODEL=openai/gpt-oss-20b
#   DEFAULT_MODEL=gpt-4o-mini
DEFAULT_MODEL=llama3.2

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (recommended local OpenAI-compatible runner on Mac)
# If LLM_PROVIDER=lmstudio, these are used automatically.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio

# llama.cpp server (OpenAI-compatible server mode)
# If LLM_PROVIDER=llamacpp, these are used automatically.
LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
LLAMACPP_API_KEY=llama.cpp

# Generic local/self-hosted OpenAI-compatible server
# Use this when the runner is not LM Studio or llama.cpp.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Cloud providers
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Search
SEARCH_ENGINE=auto
SEARXNG_URL=
BRAVE_SEARCH_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
EXA_SEARCH_TYPE=auto
EXA_TEXT_MAX_CHARACTERS=20000

# Optional integrations
GOOGLE_PLACES_API_KEY=
DEEPGRAM_API_KEY=

# Storage
SESSIONS_DB=sessions.db
AGENTS_DB=agents.db
CHROMA_DB_PATH=./chroma_db
# Active embedding model for semantic memory and retrieval.
# Examples:
#   EMBED_MODEL=nomic-embed-text
#   EMBED_MODEL=lmstudio:text-embedding-nomic-embed-text-v1.5
#   EMBED_MODEL=ollama:nomic-embed-text
# Ollama embedding transport is auto-compatible with both /api/embed and legacy /api/embeddings.
EMBED_MODEL=nomic-embed-text
EMBEDDING_HTTP_TIMEOUT=20
EMBEDDING_HTTP_RETRIES=2
EMBEDDING_CACHE_SIZE=512

# Runtime / tools
SANDBOX_DIR=./agent_sandbox
BASH_TIMEOUT=30
DOCKER_DISABLED=false
DOCKER_SANDBOX_MODE=dedicated
DOCKER_SANDBOX_IMAGE=agent-sandbox:latest
DOCKER_SANDBOX_FALLBACK_IMAGE=python:3.11-slim
DOCKER_SANDBOX_CONTAINER_NAME=agent-sandbox-exec
DOCKER_SANDBOX_WORKDIR=/workspace
DOCKER_SANDBOX_NETWORK=none
DOCKER_SANDBOX_MEMORY=512m
DOCKER_SANDBOX_PIDS_LIMIT=128
DOCKER_SANDBOX_CPU_COUNT=1.0
DOCKER_SANDBOX_TIMEOUT=30
DOCKER_SANDBOX_AUTO_PULL=false
SLIDING_WINDOW_SIZE=20
MAX_CONTEXT_LINES=80
MAX_SESSIONS=200
TRACE_DIR=./logs
TRACE_STORE_DIR=./logs/traces
TRACE_INLINE_MAX_BYTES=4096
TRACE_RECENT_CACHE=2000
TRACE_PREVIEW_CHARS=220

# Voice
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
TTS_ENGINE=auto

# Server
HOST=0.0.0.0
PORT=8000
